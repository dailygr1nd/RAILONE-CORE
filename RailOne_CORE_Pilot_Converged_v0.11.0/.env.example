# Non-secret local configuration template. Never place real credentials here.
RAILONE_DATABASE_URL=postgresql://railone:CHANGE_ME@localhost:5432/railone
RAILONE_TEST_DATABASE_URL=postgresql://railone_test:CHANGE_ME@localhost:5432/railone_test
RAILONE_ALLOW_TEST_SCHEMA_RESET=0
RAILONE_REQUIRE_LIVE_POSTGRES=0

RAILONE_MPESA_CONSUMER_KEY=
RAILONE_MPESA_CONSUMER_SECRET=
RAILONE_MPESA_INITIATOR_NAME=
RAILONE_MPESA_SECURITY_CREDENTIAL=
RAILONE_MPESA_SHORTCODE=
RAILONE_MPESA_INGRESS_HMAC_SECRET=
